# ─────────────────────────────────────────────────────────────────────────────
# Bob's Steaks & Hoagies — Environment Variables Template
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored via .env*.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Site URL ────────────────────────────────────────────────────────────────
# Full URL of the production site (no trailing slash).
# Used for webhook callback URLs and OG meta tags.
NEXT_PUBLIC_SITE_URL=https://your-domain.com


# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL: Supabase Dashboard → Project Settings → API Keys → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Publishable key — safe for browser (format: sb_publishable_...)
# Replaces the legacy anon JWT. The legacy anon key should be DISABLED in the dashboard.
# Supabase Dashboard → Project Settings → API Keys → copy the "default" publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key — server-only, bypasses RLS. NEVER expose to browser or commit to git.
# Format: sb_secret_... (NOT the legacy service_role JWT)
# Supabase Dashboard → Project Settings → API Keys → create a new secret key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...


# ─── Payment Provider ────────────────────────────────────────────────────────
# Which payment provider is active. Options: stub | clover | square | stripe | paypal
# "stub" = no real payments, useful for dev/demo. Switch to your provider for production.
PAYMENT_PROVIDER=stub


# ─── POS Provider ────────────────────────────────────────────────────────────
# Which POS system to sync orders to. Options: stub | clover | toast
POS_PROVIDER=stub


# ─── Clover Integration ───────────────────────────────────────────────────────
#
#  CLOVER_MERCHANT_ID
#    Your Merchant ID — visible in the Clover dashboard URL:
#    https://www.clover.com/dashboard/m/<MERCHANT_ID>/...
#
#  CLOVER_API_TOKEN
#    Clover Dashboard → Account & Setup → API Tokens → Generate Token
#    Required scopes: Inventory (read), Orders (read/write), Payments (read)
#
#  CLOVER_ECOMM_TOKEN
#    Clover Developer Portal → Your App → Ecommerce → Private Key
#    Starts with sk_... Required for Hosted Checkout payment links.
#
#  CLOVER_APP_ID
#    Clover Developer Portal → Your App → App ID
#
#  CLOVER_WEBHOOK_SECRET
#    Clover Developer Portal → Your App → Notifications → Signing Secret
#    Register webhook URL as: https://YOUR-DOMAIN/api/webhooks/payment?provider=clover
#
#  CLOVER_SANDBOX
#    Set "true" to use sandbox (apisandbox.dev.clover.com). "false" for production.

CLOVER_MERCHANT_ID=your-merchant-id
CLOVER_API_TOKEN=your-api-token
CLOVER_ECOMM_TOKEN=your-ecomm-private-key
CLOVER_APP_ID=your-app-id
CLOVER_WEBHOOK_SECRET=your-webhook-signing-secret
# CLOVER_ORDER_TYPE_ID=   # Optional: Clover order type ID for online/pickup orders
CLOVER_SANDBOX=true


# ─── Square Integration ───────────────────────────────────────────────────────
# Only needed if PAYMENT_PROVIDER=square
#
#  SQUARE_ACCESS_TOKEN
#    Square Developer Dashboard → Applications → Your App → OAuth → Access Token
#
#  SQUARE_LOCATION_ID
#    Square Developer Dashboard → Applications → Your App → Locations
#
#  SQUARE_WEBHOOK_SIGNATURE_KEY
#    Square Developer Dashboard → Applications → Your App → Webhooks → Signature Key
#
#  SQUARE_WEBHOOK_NOTIFICATION_URL
#    The exact URL you registered in the Square Webhooks dashboard.
#    Must match: https://YOUR-DOMAIN/api/webhooks/payment?provider=square

# SQUARE_ACCESS_TOKEN=your-square-access-token
# SQUARE_LOCATION_ID=your-location-id
# SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key
# SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-domain.com/api/webhooks/payment?provider=square


# ─── Stripe Integration ───────────────────────────────────────────────────────
# Only needed if PAYMENT_PROVIDER=stripe
#
#  STRIPE_SECRET_KEY
#    Stripe Dashboard → Developers → API Keys → Secret Key (sk_live_... or sk_test_...)
#
#  STRIPE_WEBHOOK_SECRET
#    Stripe Dashboard → Developers → Webhooks → Your endpoint → Signing Secret (whsec_...)
#    Register webhook URL as: https://YOUR-DOMAIN/api/webhooks/payment?provider=stripe

# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret


# ─── AI Chatbot (Gemini) ─────────────────────────────────────────────────────
# Google AI Studio → Get API Key: https://aistudio.google.com/app/apikey
# If not set, the chatbot falls back to the built-in rule-based responder.
GEMINI_API_KEY=your-gemini-api-key


# ─── Kitchen Display PIN ─────────────────────────────────────────────────────
# 4–8 digit PIN for the kitchen display at /kitchen.
# NEVER prefix with NEXT_PUBLIC_ — must stay server-side only.
# Validated via POST /api/kitchen/auth (not exposed to the browser bundle).
KITCHEN_PIN=your-4-to-8-digit-pin


# ─── Twilio SMS (optional — for order confirmation texts) ────────────────────
# Twilio Console → Account Info: https://console.twilio.com/
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx


# ─── Toast POS (alternative — after Toast Partner Program enrollment) ────────
# TOAST_CLIENT_ID=your-client-id
# TOAST_CLIENT_SECRET=your-client-secret
# TOAST_RESTAURANT_GUID=your-restaurant-guid
# TOAST_API_BASE=https://ws-sandbox-api.toasttab.com
# TOAST_ORDER_TYPE_GUID=your-order-type-guid
# TOAST_CUSTOM_ITEM_GUID=your-custom-item-guid
